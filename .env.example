FIRECRAWL_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Set to live to call Firecrawl. Any other value uses seeded prototype text.
COLLECTION_MODE=mock

# Set to live to call the OpenAI API for ESG signal extraction.
# Any other value uses deterministic rule-based extraction only.
AI_EXTRACTION_MODE=mock
